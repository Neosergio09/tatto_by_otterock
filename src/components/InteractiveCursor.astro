---

<canvas
    id="cosmic-cursor"
    class="fixed inset-0 pointer-events-none z-[9999] opacity-70"></canvas>

<script>
    class Point {
        x: number;
        y: number;
        constructor(x: number, y: number) {
            this.x = x;
            this.y = y;
        }
    }

    const canvas = document.getElementById(
        "cosmic-cursor"
    ) as HTMLCanvasElement;
    if (canvas) {
        const ctx = canvas.getContext("2d");

        let width = window.innerWidth;
        let height = window.innerHeight;

        function resize() {
            width = window.innerWidth;
            height = window.innerHeight;
            canvas.width = width;
            canvas.height = height;
        }
        window.addEventListener("resize", resize);
        resize();

        // Target for the head to follow
        const target = new Point(width / 2, height / 2);
        let cursorVisible = false;

        window.addEventListener("mousemove", (e: MouseEvent) => {
            target.x = e.clientX;
            target.y = e.clientY;
            cursorVisible = true;
        });

        window.addEventListener("touchmove", (e: TouchEvent) => {
            if (e.touches.length > 0) {
                target.x = e.touches[0].clientX;
                target.y = e.touches[0].clientY;
                cursorVisible = true;
            }
        });

        window.addEventListener("mouseout", () => {
            cursorVisible = false;
        });

        // Settings
        const spineLength = 25;
        const segmentLength = 6;

        const spine: Point[] = [];
        for (let i = 0; i < spineLength; i++) {
            spine.push(new Point(width / 2, height / 2));
        }

        function dist(p1: Point, p2: Point) {
            const dx = p1.x - p2.x;
            const dy = p1.y - p2.y;
            return Math.sqrt(dx * dx + dy * dy);
        }

        function angle(p1: Point, p2: Point) {
            return Math.atan2(p2.y - p1.y, p2.x - p1.x);
        }

        function resolveIK() {
            // Head follows target
            if (cursorVisible) {
                spine[0].x += (target.x - spine[0].x) * 0.25;
                spine[0].y += (target.y - spine[0].y) * 0.25;
            } else {
                // drift slightly
                spine[0].x += Math.sin(Date.now() * 0.001) * 0.5;
                spine[0].y += Math.cos(Date.now() * 0.002) * 0.5;
            }

            for (let i = 1; i < spine.length; i++) {
                const current = spine[i];
                const prev = spine[i - 1];
                let a = angle(current, prev);

                // Pull 'current' towards 'prev' maintaining 'segmentLength'
                current.x = prev.x - Math.cos(a) * segmentLength;
                current.y = prev.y - Math.sin(a) * segmentLength;
            }
        }

        // Legs
        const legAttachNodes = [2, 6, 10, 14, 18];

        class Leg {
            attachIndex: number;
            side: number;
            foot: Point;
            targetFoot: Point;
            stepping: boolean;
            stepProgress: number;
            oldFoot: Point;

            constructor(attachIndex: number, side: number) {
                this.attachIndex = attachIndex;
                this.side = side;
                this.foot = new Point(width / 2, height / 2);
                this.targetFoot = new Point(width / 2, height / 2);
                this.stepping = false;
                this.stepProgress = 0;
                this.oldFoot = new Point(width / 2, height / 2);
            }

            update(globalHeading: number) {
                const attachPoint = spine[this.attachIndex];

                let localAngle = globalHeading;
                if (this.attachIndex < spine.length - 1) {
                    localAngle = angle(
                        spine[this.attachIndex + 1],
                        spine[this.attachIndex]
                    );
                }

                // Desired foot placement relative to attach point
                const standDist = 20;
                const forwardOffset = 15;

                const perpAngle = localAngle + (Math.PI / 2) * this.side;

                this.targetFoot.x =
                    attachPoint.x +
                    Math.cos(perpAngle) * standDist +
                    Math.cos(localAngle) * forwardOffset;
                this.targetFoot.y =
                    attachPoint.y +
                    Math.sin(perpAngle) * standDist +
                    Math.sin(localAngle) * forwardOffset;

                // Step logic
                const d = dist(this.foot, this.targetFoot);
                if (d > 30 && !this.stepping) {
                    this.stepping = true;
                    this.stepProgress = 0;
                    this.oldFoot.x = this.foot.x;
                    this.oldFoot.y = this.foot.y;
                }

                if (this.stepping) {
                    // How fast it steps
                    this.stepProgress += 0.15;
                    if (this.stepProgress >= 1) {
                        this.stepProgress = 1;
                        this.stepping = false;
                    }

                    const t = this.stepProgress;
                    this.foot.x =
                        this.oldFoot.x +
                        (this.targetFoot.x - this.oldFoot.x) * t;

                    // Arc during step
                    const liftHeight = 15;
                    const arc = Math.sin(t * Math.PI) * liftHeight;
                    // Usually we lift visually by going up (-y), but here we can just offset perpendicular
                    this.foot.y =
                        this.oldFoot.y +
                        (this.targetFoot.y - this.oldFoot.y) * t -
                        arc;
                }
            }

            draw() {
                if (!ctx) return;
                const attachPoint = spine[this.attachIndex];

                ctx.beginPath();
                ctx.moveTo(attachPoint.x, attachPoint.y);

                // Knee joint
                const midX = (attachPoint.x + this.foot.x) / 2;
                const midY = (attachPoint.y + this.foot.y) / 2;

                const toFootAngle = angle(attachPoint, this.foot);
                const jointOffset = 10 * this.side; // bend knee outwards
                const jointAngle = toFootAngle + Math.PI / 2;

                const jointX = midX + Math.cos(jointAngle) * jointOffset;
                const jointY = midY + Math.sin(jointAngle) * jointOffset;

                ctx.lineTo(jointX, jointY);
                ctx.lineTo(this.foot.x, this.foot.y);
                ctx.stroke();

                // Paw
                ctx.beginPath();
                ctx.arc(this.foot.x, this.foot.y, 1.5, 0, Math.PI * 2);
                ctx.fill();
            }
        }

        const legs: Leg[] = [];
        legAttachNodes.forEach((index) => {
            legs.push(new Leg(index, 1)); // Right
            legs.push(new Leg(index, -1)); // Left
        });

        // Loop
        function draw() {
            if (!ctx) return;

            ctx.clearRect(0, 0, width, height);
            resolveIK();

            const headHeading = angle(spine[1], spine[0]);

            // Styling: Amber theme
            ctx.strokeStyle = "rgba(245, 158, 11, 0.4)"; // amber-500
            ctx.fillStyle = "rgba(245, 158, 11, 0.6)";
            ctx.lineWidth = 1;

            // Update and draw legs
            // For natural movement, alternate steps if possible, but basic threshold works nicely
            legs.forEach((leg) => {
                leg.update(headHeading);
                leg.draw();
            });

            // Draw spine body
            ctx.beginPath();
            ctx.moveTo(spine[0].x, spine[0].y);
            for (let i = 1; i < spine.length; i++) {
                ctx.lineTo(spine[i].x, spine[i].y);
            }
            ctx.stroke();

            // Draw spine segments/ribs
            for (let i = 0; i < spine.length; i++) {
                const p = spine[i];
                const size = Math.max(0.5, 3 - (i / spine.length) * 3);

                ctx.beginPath();
                ctx.arc(p.x, p.y, size, 0, Math.PI * 2);
                ctx.fill();

                // Ribs lines
                if (i % 2 === 0 && i > 0 && i < spine.length - 2) {
                    const a =
                        i < spine.length - 1
                            ? angle(spine[i + 1], spine[i])
                            : headHeading;
                    const ribLength = Math.max(1, 8 - (i / spine.length) * 8);

                    const rx = p.x + Math.cos(a + Math.PI / 2) * ribLength;
                    const ry = p.y + Math.sin(a + Math.PI / 2) * ribLength;

                    const lx = p.x + Math.cos(a - Math.PI / 2) * ribLength;
                    const ly = p.y + Math.sin(a - Math.PI / 2) * ribLength;

                    ctx.beginPath();
                    ctx.moveTo(lx, ly);
                    ctx.lineTo(rx, ry);
                    ctx.stroke();
                }
            }

            // Head (Cursor dot)
            ctx.beginPath();
            ctx.arc(spine[0].x, spine[0].y, 4, 0, Math.PI * 2);
            ctx.fillStyle = "rgba(245, 158, 11, 0.9)";
            ctx.fill();

            // Antennae
            const antLength = 12;
            const antAngleSpread = 0.4;

            // Right antenna
            ctx.beginPath();
            ctx.moveTo(spine[0].x, spine[0].y);
            ctx.lineTo(
                spine[0].x + Math.cos(headHeading + antAngleSpread) * antLength,
                spine[0].y + Math.sin(headHeading + antAngleSpread) * antLength
            );
            ctx.stroke();

            // Left antenna
            ctx.beginPath();
            ctx.moveTo(spine[0].x, spine[0].y);
            ctx.lineTo(
                spine[0].x + Math.cos(headHeading - antAngleSpread) * antLength,
                spine[0].y + Math.sin(headHeading - antAngleSpread) * antLength
            );
            ctx.stroke();

            requestAnimationFrame(draw);
        }

        // initialize local positions
        legs.forEach((leg) => {
            const attach = spine[leg.attachIndex];
            const perp = (Math.PI / 2) * leg.side; // dummy perp
            leg.foot.x = attach.x + Math.cos(perp) * 20;
            leg.foot.y = attach.y + Math.sin(perp) * 20;
        });

        draw();
    }
</script>
