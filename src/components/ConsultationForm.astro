---
import { Phone, Maximize, Palette, User, Mail, PenTool } from 'lucide-astro';
import BodyPicker3D from './BodyPicker3D.astro';

// ConsultationForm component
// Client-side interactions will map to /api/submit
---

<div class="space-y-4 rounded-xl border border-amber-500/20 bg-zinc-900/50 backdrop-blur-md p-6 shadow-[0_0_15px_rgba(0,0,0,0.5)]">
    <div class="text-center mb-6">
        <h3 class="text-2xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-amber-200 via-amber-400 to-amber-200 tracking-tighter">
            Solicitar Consulta
        </h3>
        <p class="text-zinc-400 text-sm mt-2">
            Déjanos tus datos y la idea de tu tatuaje, nos pondremos en contacto pronto.
        </p>
    </div>
    <form class="space-y-5" id="consultation-form">
        <!-- Nombre -->
        <div>
            <label class="block text-sm font-medium text-amber-200/80 mb-1.5 ml-1">Nombre Completo</label>
            <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <User class="w-5 h-5 text-zinc-500" />
                </div>
                <input
                    type="text"
                    name="name"
                    required
                    class="w-full bg-zinc-950/80 border border-zinc-800 rounded-lg pl-10 pr-4 py-2.5 text-white placeholder-zinc-600 focus:outline-none focus:border-amber-500/60 focus:ring-1 focus:ring-amber-500/60 transition-all"
                    placeholder="Escribe tu nombre"
                />
            </div>
        </div>

        <!-- Email & WhatsApp Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div>
                <label class="block text-sm font-medium text-amber-200/80 mb-1.5 ml-1">Email</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <Mail class="w-5 h-5 text-zinc-500" />
                    </div>
                    <input
                        type="email"
                        name="email"
                        required
                        class="w-full bg-zinc-950/80 border border-zinc-800 rounded-lg pl-10 pr-4 py-2.5 text-white placeholder-zinc-600 focus:outline-none focus:border-amber-500/60 focus:ring-1 focus:ring-amber-500/60 transition-all"
                        placeholder="tu@email.com"
                    />
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium text-amber-200/80 mb-1.5 ml-1">WhatsApp</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <Phone class="w-5 h-5 text-zinc-500" />
                    </div>
                    <input
                        type="tel"
                        name="whatsapp"
                        required
                        class="w-full bg-zinc-950/80 border border-zinc-800 rounded-lg pl-10 pr-4 py-2.5 text-white placeholder-zinc-600 focus:outline-none focus:border-amber-500/60 focus:ring-1 focus:ring-amber-500/60 transition-all"
                        placeholder="+1234567890"
                    />
                </div>
            </div>
        </div>

        <!-- 3D Body Picker -->
        <BodyPicker3D />

        <!-- Zona del Cuerpo & Tamaño Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div>
                <label class="block text-sm font-medium text-amber-200/80 mb-1.5 ml-1">Zona del Cuerpo</label>
                <select id="body-part-select" name="body_part" required class="w-full bg-zinc-950/80 border border-zinc-800 rounded-lg px-4 py-2.5 text-white placeholder-zinc-600 focus:outline-none focus:border-amber-500/60 focus:ring-1 focus:ring-amber-500/60 transition-all appearance-none cursor-pointer">
                    <option value="" disabled selected hidden>Seleccionar zona</option>
                    <option value="Brazo">Brazo</option>
                    <option value="Pierna">Pierna</option>
                    <option value="Espalda">Espalda</option>
                    <option value="Pecho">Pecho</option>
                    <option value="Otro">Otro</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-amber-200/80 mb-1.5 ml-1">Tamaño (cm)</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <Maximize class="w-5 h-5 text-zinc-500" />
                    </div>
                    <input
                        type="number"
                        name="size_cm"
                        min="1"
                        required
                        class="w-full bg-zinc-950/80 border border-zinc-800 rounded-lg pl-10 pr-4 py-2.5 text-white placeholder-zinc-600 focus:outline-none focus:border-amber-500/60 focus:ring-1 focus:ring-amber-500/60 transition-all appearance-none"
                        placeholder="Ej. 10"
                    />
                </div>
            </div>
        </div>

        <!-- Estilo -->
        <div>
            <label class="block text-sm font-medium text-amber-200/80 mb-1.5 ml-1">Estilo</label>
            <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <Palette class="w-5 h-5 text-zinc-500" />
                </div>
                <select name="style" required class="w-full bg-zinc-950/80 border border-zinc-800 rounded-lg pl-10 pr-4 py-2.5 text-white placeholder-zinc-600 focus:outline-none focus:border-amber-500/60 focus:ring-1 focus:ring-amber-500/60 transition-all appearance-none cursor-pointer">
                    <option value="" disabled selected hidden>Elige un estilo</option>
                    <option value="Realismo">Realismo</option>
                    <option value="Blackwork">Blackwork</option>
                    <option value="Minimalista">Minimalista</option>
                    <option value="Tradicional">Tradicional</option>
                </select>
            </div>
        </div>

        <!-- Idea -->
        <div>
            <label class="block text-sm font-medium text-amber-200/80 mb-1.5 ml-1">Idea del Tatuaje</label>
            <div class="relative">
                <div class="absolute top-3 left-3 pointer-events-none">
                    <PenTool class="w-5 h-5 text-zinc-500" />
                </div>
                <textarea
                    name="description"
                    rows="3"
                    required
                    class="w-full bg-zinc-950/80 border border-zinc-800 rounded-lg pl-10 pr-4 py-2.5 text-white placeholder-zinc-600 focus:outline-none focus:border-amber-500/60 focus:ring-1 focus:ring-amber-500/60 transition-all resize-none"
                    placeholder="Describe en detalle tu idea..."></textarea>
            </div>
        </div>

        <button
            type="submit"
            class="w-full bg-gradient-to-r from-amber-600 to-amber-500 hover:from-amber-500 hover:to-amber-400 text-zinc-950 font-bold tracking-wide py-3.5 px-4 rounded-lg transition-all shadow-lg hover:shadow-[0_0_20px_rgba(245,158,11,0.6)] mt-4 active:scale-[0.98]"
        >
            <span class="submit-text">Enviar Solicitud</span>
            <span class="loading-spinner hidden">Enviando...</span>
        </button>
        
        <div id="form-message" class="hidden rounded-md p-3 text-sm text-center"></div>
    </form>
</div>

<script>
    const form = document.getElementById('consultation-form') as HTMLFormElement;
    const submitBtn = form?.querySelector('button[type="submit"]');
    const submitText = form?.querySelector('.submit-text');
    const loadingSpinner = form?.querySelector('.loading-spinner');
    const formMessage = document.getElementById('form-message');

    const bodyPartSelect = document.getElementById('body-part-select') as HTMLSelectElement;
    if (bodyPartSelect) {
        window.addEventListener('bodyPartSelected', ((e: CustomEvent) => {
            bodyPartSelect.value = e.detail.partName;
        }) as EventListener);
        
        bodyPartSelect.addEventListener('change', (e) => {
            const event = new CustomEvent('formBodyPartChanged', { detail: { partName: (e.target as HTMLSelectElement).value } });
            window.dispatchEvent(event);
        });
    }

    if (form) {
        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            if (!submitBtn || !submitText || !loadingSpinner || !formMessage) return;

            // Loading state
            submitBtn.setAttribute('disabled', 'true');
            submitText.classList.add('hidden');
            loadingSpinner.classList.remove('hidden');
            formMessage.className = 'hidden';

            try {
                const formData = new FormData(form);
                const response = await fetch('/api/submit', {
                    method: 'POST',
                    body: formData,
                });

                const result = await response.json();

                if (response.ok) {
                    form.reset();
                    formMessage.textContent = '¡Solicitud enviada con éxito! Nos comunicaremos pronto.';
                    formMessage.className = 'block rounded-md p-3 text-sm text-center bg-green-900/40 text-green-400 border border-green-800/50 mt-4';
                } else {
                    throw new Error(result.error || 'Error enviando el formulario');
                }
            } catch (err: any) {
                formMessage.textContent = err.message || 'Ha ocurrido un error inesperado. Intenta de nuevo.';
                formMessage.className = 'block rounded-md p-3 text-sm text-center bg-red-900/40 text-red-400 border border-red-800/50 mt-4';
            } finally {
                // Restore state
                submitBtn.removeAttribute('disabled');
                submitText.classList.remove('hidden');
                loadingSpinner.classList.add('hidden');
            }
        });
    }
</script>
