---
// Footer.astro - Minimalist Otterock Drop Experience
---

<footer
    class="bg-zinc-950 border-t border-amber-500/10 py-20 mt-auto flex flex-col items-center justify-center overflow-hidden"
>
    <div class="max-w-7xl mx-auto w-full px-6 flex justify-center items-center">
        <div
            class="relative w-full text-center flex items-center justify-center min-h-[30px]"
        >
            <!-- The Drop -->
            <div
                class="absolute w-2.5 h-2.5 bg-amber-500 rounded-full animate-water-drop-fluid"
                style="will-change: transform, opacity;"
            >
            </div>

            <!-- The Text -->
            <p
                class="text-xs sm:text-sm uppercase tracking-[0.2em] whitespace-nowrap opacity-0 animate-text-reveal-fluid text-zinc-400 mx-auto"
                style="will-change: transform, opacity, filter;"
            >
                Una experiencia diseñada por <span class="font-bold text-white"
                    >Otterock</span
                >
            </p>
        </div>
    </div>
</footer>

<style is:global>
    @keyframes drop-fluid {
        /* Phase 1: Gravity (0% - 70%) */
        0% {
            opacity: 0;
            transform: translateY(-50px) scale(0.3);
        }
        20% {
            opacity: 1;
            transform: translateY(-10px) scale(0.9);
        }
        50% {
            opacity: 1;
            transform: translateY(-25px) scale(0.7);
        }
        70% {
            opacity: 1;
            transform: translateY(0px) scale(1.2);
        }
        /* Phase 2: Viscous Expansion (70% - 100%) */
        80% {
            opacity: 1;
            transform: translateY(0px) scaleX(3) scaleY(0.4);
        }
        100% {
            opacity: 0;
            transform: translateY(0px) scaleX(5) scaleY(0.1);
        }
    }

    @keyframes text-reveal-fluid {
        0%,
        70% {
            opacity: 0;
            filter: blur(5px);
            transform: scale(0.95);
        }
        100% {
            opacity: 1;
            filter: blur(0);
            transform: scale(1);
        }
    }

    .animate-water-drop-fluid {
        animation: drop-fluid 3.5s cubic-bezier(0.19, 1, 0.22, 1) forwards
            infinite;
    }

    .animate-text-reveal-fluid {
        animation: text-reveal-fluid 3.5s cubic-bezier(0.19, 1, 0.22, 1)
            forwards infinite;
    }
</style>
