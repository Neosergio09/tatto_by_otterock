---
import { Instagram, MapPin, ExternalLink } from "lucide-astro";
---

<footer
    class="bg-zinc-950 border-t border-amber-500/20 pt-16 pb-8 px-6 mt-auto"
>
    <div class="max-w-7xl mx-auto">
        <!-- Footer Top: 3 Columns -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-16">
            <!-- Brand Column -->
            <div class="flex flex-col space-y-4">
                <a
                    href="/"
                    class="text-2xl font-bold tracking-widest text-white flex items-baseline"
                >
                    BARRIENTOSINK<span
                        class="text-amber-500 ml-0.5 text-3xl leading-none"
                        >.</span
                    >
                </a>
                <p class="text-zinc-400 font-medium tracking-wide">
                    El arte es eterno.
                </p>
                <div class="flex space-x-4 pt-2">
                    <a
                        href="#"
                        class="w-10 h-10 rounded-full border border-zinc-800 flex items-center justify-center text-zinc-400 hover:text-amber-500 hover:border-amber-500 transition-colors"
                    >
                        <Instagram class="w-5 h-5" />
                    </a>
                </div>
            </div>

            <!-- Links Column -->
            <div class="flex flex-col space-y-4">
                <h3
                    class="text-xl font-bold text-white tracking-widest uppercase mb-2"
                >
                    Explorar
                </h3>
                <a
                    href="/artistas"
                    class="text-zinc-400 hover:text-amber-500 transition-colors w-fit"
                    >Artistas</a
                >
                <a
                    href="/portafolio"
                    class="text-zinc-400 hover:text-amber-500 transition-colors w-fit"
                    >Portafolio</a
                >
                <a
                    href="/contacto"
                    class="text-amber-500 font-medium hover:text-white transition-colors flex items-center gap-2 w-fit pt-2"
                >
                    Agendar Cita <ExternalLink class="w-4 h-4" />
                </a>
            </div>

            <!-- Legal / Info Column -->
            <div class="flex flex-col space-y-4">
                <h3
                    class="text-xl font-bold text-white tracking-widest uppercase mb-2"
                >
                    Estudio
                </h3>
                <p class="text-zinc-400 flex items-start gap-2">
                    <MapPin class="w-5 h-5 text-amber-500 shrink-0 mt-0.5" />
                    <span>Estudio Privado<br />Bogotá, Colombia</span>
                </p>
                <div class="pt-4 flex flex-col space-y-2 text-sm">
                    <a
                        href="#"
                        class="text-zinc-500 hover:text-zinc-300 transition-colors"
                        >Políticas de Privacidad</a
                    >
                    <a
                        href="#"
                        class="text-zinc-500 hover:text-zinc-300 transition-colors"
                        >Términos y Condiciones</a
                    >
                </div>
            </div>
        </div>

        <!-- Footer Bottom: The Otterock Drop -->
        <div
            class="border-t border-white/5 pt-8 pb-4 flex justify-center items-center overflow-hidden min-h-[80px]"
        >
            <div
                class="relative w-full text-center flex items-center justify-center min-h-[30px]"
            >
                <!-- The Drop -->
                <div
                    class="absolute w-2.5 h-2.5 bg-amber-500 rounded-full animate-water-drop"
                    style="will-change: transform, opacity;"
                >
                </div>

                <!-- The Text -->
                <p
                    class="text-xs uppercase tracking-[0.2em] whitespace-nowrap opacity-0 animate-text-reveal text-zinc-400 mx-auto"
                    style="will-change: transform, opacity, filter;"
                >
                    Una experiencia diseñada por <span
                        class="font-bold text-white">Otterock</span
                    >
                </p>
            </div>
        </div>
    </div>
</footer>
