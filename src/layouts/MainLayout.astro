---
import "../styles/global.css";
import Footer from "../components/Footer.astro";
import GenerativeLifeform from "../components/GenerativeLifeform.astro";

interface Props {
    /** Title of the page, defaults to "Otterock | Tattoo Studio" */
    title?: string;
    /** Description for SEO */
    description?: string;
}

const {
    title = "Otterock | Tattoo Studio",
    description = "A premium management platform for modern tattoo artists.",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <meta name="description" content={description} />
    </head>
    <body
        class="bg-zinc-950 text-zinc-100 antialiased selection:bg-amber-500/30 flex flex-col min-h-screen relative"
    >
        <!-- Background radial gradient (Gold glow at top right) -->
        <div
            class="fixed inset-0 z-[-1] pointer-events-none bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-amber-900/10 via-transparent to-transparent"
        >
        </div>

        <!-- Elegant Sticky Glassmorphism Header -->
        <header
            class="w-full sticky top-0 z-50 bg-zinc-950/80 backdrop-blur-md border-b border-amber-500/20 px-6 py-4"
        >
            <div class="max-w-7xl mx-auto flex items-center justify-between">
                <!-- Logo -->
                <a
                    href="/"
                    class="text-xl md:text-2xl font-bold tracking-widest text-white flex items-baseline hover:opacity-90 transition-opacity"
                >
                    OTTEROCK<span
                        class="text-amber-500 ml-0.5 text-2xl md:text-3xl leading-none"
                        >.</span
                    >
                </a>

                <!-- Desktop Navigation Links -->
                <nav
                    class="hidden md:flex items-center space-x-8 text-sm font-medium text-zinc-300"
                >
                    <a
                        href="/"
                        class="hover:text-amber-500 transition-colors"
                        data-astro-prefetch>Inicio</a
                    >
                    <a
                        href="/artistas"
                        class="hover:text-amber-500 transition-colors"
                        data-astro-prefetch>Artistas</a
                    >
                    <a
                        href="/portafolio"
                        class="hover:text-amber-500 transition-colors"
                        data-astro-prefetch>Portafolio</a
                    >
                    <a
                        href="/contacto"
                        class="hover:text-amber-500 transition-colors"
                        data-astro-prefetch>Contacto</a
                    >
                </nav>
            </div>
        </header>

        <!-- Main Content Area -->
        <main
            class="flex-grow flex flex-col w-full max-w-7xl mx-auto px-6 py-8"
        >
            <slot />
        </main>

        <!-- Premium Footer -->
        <Footer />
        <GenerativeLifeform />
    </body>
</html>
