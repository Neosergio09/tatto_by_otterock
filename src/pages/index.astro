---
import MainLayout from "../layouts/MainLayout.astro";
import ConsultationForm from "../components/ConsultationForm.astro";
import { PenTool, ShieldCheck, Sparkles } from "lucide-astro";
---

<MainLayout title="BarrientosINK | Estudio de Diseño Privado">
	<div
		class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20 mt-12 md:mt-24 mb-20"
	>
		<!-- Hero Content -->
		<div class="flex-1 text-center lg:text-left">
			<h1
				class="text-5xl md:text-6xl lg:text-7xl font-bold tracking-tighter mb-6 text-zinc-100 leading-tight"
			>
				BarrientosINK: <br class="hidden lg:block" />
				<span class="text-amber-500"
					>Donde el Arte se Funde con la Piel.</span
				>
			</h1>
			<p
				class="text-zinc-400 text-lg md:text-xl leading-relaxed max-w-2xl mx-auto lg:mx-0"
			>
				Estudio de diseño privado especializado en piezas de autor y
				realismo fino. Tu historia merece ser inmortalizada con
				precisión y elegancia.
			</p>
		</div>

		<!-- Form Container with Gold Glow -->
		<div id="patrol-trigger" class="w-full max-w-md lg:w-[400px] relative group shrink-0">
			<!-- Gold Dust Halo Effect -->
			<div
				id="patrol-target"
				class="absolute -inset-2 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-amber-500/40 via-amber-700/10 to-transparent rounded-[2rem] blur-xl opacity-60 group-hover:opacity-100 group-hover:blur-2xl transition-all duration-1000 group-hover:duration-500"
			>
			</div>

			<!-- Form Content -->
			<div
				class="relative bg-zinc-950 p-6 sm:p-8 rounded-xl border border-amber-500/20 shadow-[0_0_40px_-10px_rgba(245,158,11,0.15)] group-hover:border-amber-500/40 transition-colors duration-500"
			>
				<ConsultationForm />
			</div>
		</div>
	</div>

	<!-- Value Props Grid -->
	<div
		class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-20 border-t border-amber-500/10 pt-16 mt-16 relative"
	>
		<!-- Subtle background gradient line -->
		<div
			class="absolute top-0 left-1/2 -translate-x-1/2 w-1/2 h-[1px] bg-gradient-to-r from-transparent via-amber-500/50 to-transparent"
		>
		</div>

		<!-- Item 1: Diseño Único -->
		<div
			class="bg-zinc-900/40 p-8 rounded-2xl border border-white/5 hover:border-amber-500/30 transition-all hover:-translate-y-1 duration-300"
		>
			<div
				class="w-12 h-12 bg-amber-500/10 rounded-xl flex items-center justify-center mb-6 text-amber-500 relative overflow-hidden group"
			>
				<div
					class="absolute inset-0 bg-amber-500/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300 ease-out"
				>
				</div>
				<PenTool class="w-6 h-6 relative z-10" />
			</div>
			<h3 class="text-xl font-bold tracking-tighter text-zinc-100 mb-3">
				Diseño Único
			</h3>
			<p class="text-zinc-400 leading-relaxed text-sm lg:text-base">
				No replicamos. Creamos piezas exclusivas para cada lienzo
				humano.
			</p>
		</div>

		<!-- Item 2: Higiene Médica -->
		<div
			class="bg-zinc-900/40 p-8 rounded-2xl border border-white/5 hover:border-amber-500/30 transition-all hover:-translate-y-1 duration-300"
		>
			<div
				class="w-12 h-12 bg-amber-500/10 rounded-xl flex items-center justify-center mb-6 text-amber-500 relative overflow-hidden group"
			>
				<div
					class="absolute inset-0 bg-amber-500/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300 ease-out"
				>
				</div>
				<ShieldCheck class="w-6 h-6 relative z-10" />
			</div>
			<h3 class="text-xl font-bold tracking-tighter text-zinc-100 mb-3">
				Higiene Médica
			</h3>
			<p class="text-zinc-400 leading-relaxed text-sm lg:text-base">
				Estándares quirúrgicos para tu total tranquilidad.
			</p>
		</div>

		<!-- Item 3: Asesoría IA -->
		<div
			class="bg-zinc-900/40 p-8 rounded-2xl border border-white/5 hover:border-amber-500/30 transition-all hover:-translate-y-1 duration-300"
		>
			<div
				class="w-12 h-12 bg-amber-500/10 rounded-xl flex items-center justify-center mb-6 text-amber-500 relative overflow-hidden group"
			>
				<div
					class="absolute inset-0 bg-amber-500/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300 ease-out"
				>
				</div>
				<Sparkles class="w-6 h-6 relative z-10" />
			</div>
			<h3 class="text-xl font-bold tracking-tighter text-zinc-100 mb-3">
				Asesoría IA
			</h3>
			<p class="text-zinc-400 leading-relaxed text-sm lg:text-base">
				Visualiza y cotiza tu idea con nuestra tecnología de vanguardia.
			</p>
		</div>
	</div>
</MainLayout>
