---
import MainLayout from '../layouts/MainLayout.astro';
import { Instagram, Star } from 'lucide-astro';
import { Image } from 'astro:assets';

const artists = [
  {
    name: "Victor Barrientos",
    specialty: "Master Realism",
    imageUrl: "https://images.unsplash.com/photo-1598371839696-5c5bb00bdc28?auto=format&fit=crop&q=80&w=800",
  },
  {
    name: "Elena Silva",
    specialty: "Fine Line & Dotwork",
    imageUrl: "https://images.unsplash.com/photo-1611558709798-e009c8fd7706?auto=format&fit=crop&q=80&w=800",
  },
  {
    name: "Marcos Torres",
    specialty: "Japanese Traditional",
    imageUrl: "https://images.unsplash.com/photo-1550537687-c91072c4792d?auto=format&fit=crop&q=80&w=800",
  }
];
---

<MainLayout title="Artistas | BarrientosINK">
  <div class="py-12 md:py-20 text-center max-w-3xl mx-auto mb-12">
    <h1 class="text-4xl md:text-6xl font-bold tracking-tighter mb-4 text-white">
      Nuestros <span class="text-amber-500">Artistas</span>
    </h1>
    <p class="text-zinc-400 text-lg">
      Maestros de la aguja con estilos únicos. Descubre el talento detrás de BarrientosINK.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
    {artists.map((artist) => (
      <div class="flex flex-col group">
        <!-- Filigree Frame (Double border with amber accent) -->
        <div class="p-2 border-[6px] border-double border-amber-500/50 rounded-lg bg-zinc-950 shadow-2xl transition duration-500 group-hover:border-amber-500/80">
          <div class="overflow-hidden bg-zinc-900 rounded aspect-[3/4] relative">
            <Image 
              src={artist.imageUrl} 
              alt={artist.name}
              width={800}
              height={1066}
              format="webp"
              loading="lazy" 
              class="w-full h-full object-cover grayscale opacity-80 transition duration-700 group-hover:grayscale-0 group-hover:scale-105 group-hover:opacity-100"
            />
          </div>
        </div>
        
        <!-- Artist Info -->
        <div class="mt-6 text-center space-y-2">
          <h2 class="text-2xl font-bold text-white tracking-widest">{artist.name}</h2>
          <div class="flex items-center justify-center space-x-2 text-amber-500">
            <Star class="w-4 h-4" />
            <p class="text-sm font-medium uppercase tracking-widest">{artist.specialty}</p>
            <Star class="w-4 h-4" />
          </div>
          <button class="mt-4 flex items-center justify-center space-x-2 w-full max-w-[200px] mx-auto py-2 px-4 border border-zinc-800 rounded-lg hover:border-amber-500 hover:text-amber-500 text-zinc-400 transition-colors">
            <Instagram class="w-4 h-4" />
            <span class="text-sm font-medium">Ver Portafolio</span>
          </button>
        </div>
      </div>
    ))}
  </div>
</MainLayout>
