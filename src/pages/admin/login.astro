---
import MainLayout from '../../layouts/MainLayout.astro';
import GenerativeLifeform from '../../components/GenerativeLifeform.astro';
import { createApiClient } from '../../lib/db';

let errorMsg = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const email = formData.get('email')?.toString();
  const password = formData.get('password')?.toString();

  if (email && password) {
    const supabase = createApiClient(Astro);
    
    const { error } = await supabase.auth.signInWithPassword({
      email,
      password,
    });

    if (error) {
      errorMsg = 'Credenciales inválidas.';
    } else {
      return Astro.redirect('/admin/dashboard');
    }
  } else {
    errorMsg = 'Por favor, llena todos los campos.';
  }
}
---

<MainLayout title="Admin Login | Otterock" headerTransparent={true}>
  <div class="relative w-full h-screen overflow-hidden bg-zinc-950 flex items-center justify-center">
    <!-- Snake in background -->
    <div class="absolute inset-0 z-0 opacity-40">
      <GenerativeLifeform />
    </div>

    <!-- Login Box -->
    <div class="relative z-10 w-full max-w-md p-8 bg-zinc-900/80 backdrop-blur-xl border border-amber-500/20 rounded-2xl shadow-[0_0_30px_rgba(0,0,0,0.8)]">
      <div class="text-center mb-8">
        <h1 class="text-3xl font-black text-transparent bg-clip-text bg-gradient-to-r from-amber-200 to-amber-500 tracking-tighter">
          Otterock Engine
        </h1>
        <p class="text-zinc-400 text-sm mt-2">Acceso a la Bóveda de Consultas</p>
      </div>

      {errorMsg && (
        <div class="mb-6 p-3 rounded-lg bg-red-500/10 border border-red-500/20 text-red-400 text-sm text-center">
          {errorMsg}
        </div>
      )}

      <form method="POST" class="space-y-5">
        <div>
          <label class="block text-sm font-medium text-amber-200/80 mb-1.5 ml-1">Email</label>
          <input 
            type="email" 
            name="email" 
            required 
            placeholder="admin@otterock.com"
            class="w-full bg-zinc-950/80 border border-zinc-800 rounded-lg px-4 py-3 text-white placeholder-zinc-600 focus:outline-none focus:border-amber-500/60 focus:ring-1 focus:ring-amber-500/60 transition-all"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-amber-200/80 mb-1.5 ml-1">Contraseña</label>
          <input 
            type="password" 
            name="password" 
            required 
            placeholder="••••••••"
            class="w-full bg-zinc-950/80 border border-zinc-800 rounded-lg px-4 py-3 text-white placeholder-zinc-600 focus:outline-none focus:border-amber-500/60 focus:ring-1 focus:ring-amber-500/60 transition-all"
          />
        </div>

        <button 
          type="submit"
          class="w-full bg-gradient-to-r from-amber-600 to-amber-500 hover:from-amber-500 hover:to-amber-400 text-zinc-950 font-bold tracking-wide py-3.5 px-4 rounded-lg transition-all shadow-lg hover:shadow-[0_0_20px_rgba(245,158,11,0.6)] mt-2 active:scale-[0.98]"
        >
          Entrar a la Bóveda
        </button>
      </form>
    </div>
  </div>
</MainLayout>
