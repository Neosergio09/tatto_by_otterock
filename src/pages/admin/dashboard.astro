---
import MainLayout from '../../layouts/MainLayout.astro';
import { createApiClient } from '../../lib/db';
import { LogOut, ExternalLink, Mail, Phone, Clock, Maximize, Palette } from 'lucide-astro';

const supabase = createApiClient(Astro);

// Check authentication
const { data: { session }, error: sessionError } = await supabase.auth.getSession();

if (sessionError || !session) {
  return Astro.redirect('/admin/login');
}

// Fetch leads (consultations)
// Because we have RLS enabled, fetching from `consultations` will automatically filter
// based on the logged-in user's profile_id (since `auth.uid() = profile_id` policy exists)
const { data: leads, error } = await supabase
  .from('consultations')
  .select('*')
  .order('created_at', { ascending: false });
---

<MainLayout title="Admin Dashboard | Otterock" headerTransparent={true}>
  <div class="min-h-screen bg-zinc-950 text-white font-sans pt-20 pb-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      
      <!-- Header -->
      <div class="flex flex-col md:flex-row md:items-start justify-between gap-4 mb-8">
        <div>
          <h1 class="text-3xl font-black text-transparent bg-clip-text bg-gradient-to-r from-amber-200 to-amber-500 tracking-tighter">
            Bóveda de Consultas
          </h1>
          <p class="text-zinc-400 text-sm mt-1">Conectado como: {session.user.email}</p>
        </div>
        
        <form method="POST" action="/api/auth/logout">
          <button type="submit" class="flex items-center gap-2 text-zinc-400 hover:text-red-400 transition-colors bg-zinc-900 border border-zinc-800 hover:border-red-900/50 px-4 py-2 rounded-lg text-sm font-medium shadow-[0_4px_10px_rgba(0,0,0,0.5)] active:scale-95">
            <LogOut class="w-4 h-4" />
            <span>Cerrar Sesión</span>
          </button>
        </form>
      </div>

      <!-- Dashboard Grid / Table -->
      <div class="bg-zinc-900/50 backdrop-blur-md border border-zinc-800/80 rounded-2xl overflow-hidden shadow-[0_0_30px_rgba(0,0,0,0.6)]">
        {error && (
          <div class="p-6 bg-red-900/20 text-red-400 border-b border-zinc-800">
            Error cargando consultas: {error.message}
          </div>
        )}
        
        {!leads || leads.length === 0 ? (
          <div class="p-16 text-center text-zinc-500">
            <p class="text-lg">No hay consultas registradas aún.</p>
            <p class="text-sm mt-2">Los leads que envíen datos con tu perfil aparecerán aquí.</p>
          </div>
        ) : (
          <div class="overflow-x-auto">
            <table class="w-full text-left text-sm whitespace-nowrap">
              <thead class="uppercase bg-zinc-950/80 text-zinc-400 text-xs tracking-wider border-b border-amber-500/20">
                <tr>
                  <th scope="col" class="px-6 py-4 font-semibold">Cliente</th>
                  <th scope="col" class="px-6 py-4 font-semibold">Proyecto</th>
                  <th scope="col" class="px-6 py-4 font-semibold">Detalles</th>
                  <th scope="col" class="px-6 py-4 font-semibold text-right">Acciones</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-zinc-800/50">
                {leads.map((lead: any) => (
                  <tr class="hover:bg-zinc-800/20 transition-colors group">
                    <td class="px-6 py-4">
                      <div class="font-bold text-amber-50">{lead.name}</div>
                      <div class="text-zinc-400 text-xs flex items-center gap-3 mt-1.5">
                        <span class="flex items-center gap-1"><Mail class="w-3 h-3"/> {lead.email}</span>
                        <span class="flex items-center gap-1"><Phone class="w-3 h-3"/> {lead.whatsapp}</span>
                      </div>
                      <div class="text-zinc-500 text-[10px] mt-2 flex items-center gap-1">
                        <Clock class="w-3 h-3" />
                        {new Date(lead.created_at).toLocaleDateString()}
                      </div>
                    </td>
                    <td class="px-6 py-4 max-w-[200px]">
                      <div class="flex items-center gap-2 mb-1">
                        <span class="px-2 py-0.5 rounded-full bg-amber-500/10 text-amber-400 text-xs border border-amber-500/20 font-medium">
                          {lead.style || 'Sin Estilo'}
                        </span>
                      </div>
                      <p class="text-zinc-300 whitespace-normal text-sm line-clamp-2" title={lead.description}>
                        {lead.description}
                      </p>
                    </td>
                    <td class="px-6 py-4 text-zinc-300">
                      <div class="flex flex-col gap-1 text-xs">
                        <span class="flex items-center gap-1"><span class="text-zinc-500">Zona:</span> {lead.body_part}</span>
                        <span class="flex items-center gap-1"><Maximize class="w-3 h-3 text-zinc-500"/> {lead.size_cm} cm</span>
                      </div>
                    </td>
                    <td class="px-6 py-4 text-right">
                      {lead.reference_url ? (
                        <a href={lead.reference_url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 bg-zinc-800 hover:bg-zinc-700 text-amber-200 hover:text-amber-100 px-3 py-1.5 rounded-lg transition-colors border border-amber-900/30 text-xs font-semibold">
                          <span>Ver Ref</span>
                          <ExternalLink class="w-3.5 h-3.5" />
                        </a>
                      ) : (
                        <span class="text-zinc-600 text-xs italic">Sin Img</span>
                      )}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>

    </div>
  </div>
</MainLayout>
